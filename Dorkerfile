# Usa uma imagem oficial do Python super leve e rápida
FROM python:3.10-slim

# Define a pasta de trabalho lá dentro
WORKDIR /app

# Instala as ferramentas do sistema necessárias para o PostgreSQL e o Pandas rodarem lisos
RUN apt-get update && apt-get install -y libpq-dev gcc && rm -rf /var/lib/apt/lists/*

# Copia as bibliotecas e instala tudo
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copia o resto do teu código (incluindo o app.py e a imagem da Postal Saúde)
COPY . .

# O comando blindado definitivo (usa a porta dinâmica do Railway e dá 120s de paciência)
CMD sh -c "gunicorn app:app -b 0.0.0.0:${PORT:-5000} --timeout 120 --workers 1 --threads 2"
